APP_NAME="Meridian Open Science"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# utf8mb4 IS NOT OPTIONAL. This machine's MySQL server defaults to latin1, and
# cPanel's database wizard often does too. Author names carry diacritics (Papé,
# Ramírez, Sørensen) and titles carry en-dashes and curly quotes — a latin1 column
# corrupts those SILENTLY. No error, just mangled characters that then get deposited
# to Crossref and propagate to every index that consumes it.
#
# Create the database explicitly, never through a GUI default:
#   CREATE DATABASE lcc_journal CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lcc_journal
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Where uploaded images (journal covers, hero photos) are served from. Leave this UNSET
# unless you need it: the default is the root-relative '/storage', which resolves against
# whatever origin served the page, so `artisan serve`, an Apache vhost and cPanel all work
# with nothing to keep in sync. Set it only if:
#   - the app is served from a SUBDIRECTORY rather than the root of its own host, e.g.
#     PUBLIC_DISK_URL=/lcc-journal-system/public/storage
#   - assets move to a CDN or bucket, which needs a full absolute origin
# Do NOT point it at APP_URL. That was the old behaviour and it broke every image on the
# site whenever the browsed host differed from the one in .env.
# PUBLIC_DISK_URL=

# Crossref deposits run on the queue. Without a worker, articles publish correctly
# and NO DOI IS EVER REGISTERED — and because publish is deliberately decoupled from
# Crossref, nothing will look wrong.
QUEUE_CONNECTION=database
CACHE_STORE=database

# Locally, mail goes to storage/logs/laravel.log rather than to real reviewers.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="journal@lcc.ac.uk"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Inertia SSR  (run: php artisan inertia:start-ssr)
# ---------------------------------------------------------------------------
# If this process is down, Inertia does NOT error — it silently falls back to
# client-side rendering. Humans still see a working site; every crawler sees an empty
# page, and every DOI pointing at it resolves to something no index can read. The
# failure is invisible, which is why `php artisan journal:check-ssr` exists.
INERTIA_SSR_ENABLED=true
# KEEP THIS http:// EVEN IN PRODUCTION, where APP_URL is https://. The SSR server is a plain
# Node HTTP listener on loopback — no certificate, no TLS — and it needs none, because the
# traffic never leaves the host. Setting https:// here to match APP_URL fails the handshake
# on every render, and Inertia swallows it: the site looks fine and is invisible to crawlers.
INERTIA_SSR_URL=http://127.0.0.1:13714

# ---------------------------------------------------------------------------
# Crossref
# ---------------------------------------------------------------------------
# DEFAULTS TO SANDBOX. Setting this to `production` mints permanent, public
# identifiers and spends the journal's deposit allowance. There is no undo.
# Per-journal credentials live encrypted on the journals table; these are a fallback.
CROSSREF_ENDPOINT=sandbox
CROSSREF_DEPOSITOR_NAME="London Churchill College"
CROSSREF_DEPOSITOR_EMAIL=journal@lcc.ac.uk
CROSSREF_REGISTRANT="London Churchill College"
CROSSREF_USERNAME=
CROSSREF_PASSWORD=
