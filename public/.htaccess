# Meridian — Apache config for the production build, served at the domain root.
#
# This is a single-page app: the server only ever has index.html on disk. Without the
# rewrite below, refreshing /dashboard or opening a shared article link would return a
# 404, because no such file exists — React Router resolves those paths in the browser,
# after index.html has loaded.
#
# Deploying into a subfolder instead? Set RewriteBase and the RewriteRule target to
# match, and rebuild with VITE_BASE=/that-folder/ npm run build.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Anything that exists on disk (assets, images, favicon) is served directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else hands off to the app.
  RewriteRule . /index.html [L]
</IfModule>

# Asset filenames are content-hashed by Vite, so they can be cached hard and forever.
# index.html must never be cached, or a deploy won't reach anyone holding a stale copy.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|svg|png|jpg|jpeg|webp|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
